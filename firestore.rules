rules_version = '2';

// All writes go through the Firebase Admin SDK on the server (Next.js route
// handlers / server actions). The client SDK is only used for authentication
// (popup login) and is never allowed to write directly to Firestore.
//
// Reads are restricted to public content only. Everything else is Admin-only.

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny — every rule below must explicitly allow access.
    match /{document=**} {
      allow read, write: if false;
    }

    // Posts — public can read only published posts.
    match /posts/{postId} {
      allow read: if resource.data.published == true;
      allow write: if false; // Admin SDK only

      // Per-user interactions (likes / views). The client never reads or
      // writes these directly; the Next.js API routes operate on them
      // through the Admin SDK, which bypasses these rules.
      match /likes/{visitorId} {
        allow read, write: if false;
      }

      match /views/{viewId} {
        allow read, write: if false;
      }
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if false;
    }

    match /contacts/{contactId} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if false;
    }

    // Per-visitor aggregates for liked/saved posts. Admin SDK only — the
    // client hydrates via /api/me which reads these server-side.
    match /visitors/{visitorId}/{document=**} {
      allow read, write: if false;
    }

    match /siteConfig/{settingId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
