{
    "hosting": {
      "public": "frontend/out",
      "source": "frontend",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "function": "api"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    "functions": [
      {
        "source": "functions",
        "codebase": "default",
        "runtime": "nodejs22"
      }
    ],
    "emulators": {
      "hosting": {
        "port": 3000
      },
      "functions": {
        "port": 5001
      },
      "firestore": {
        "port": 8080
      },
      "ui": {
        "enabled": true,
        "port": 4000
      },
      "singleProjectMode": true
    },
    "firestore": {
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  }