# infra/listmonk/.env.example
# Copy to `infra/listmonk/.env` for local dev, or set the same vars in the
# Railway service environment for prod. Never commit the populated file.
#
# Two deployment targets share this file:
#   local    docker compose --profile local   (db + app)
#   railway  docker compose --profile railway (app only; DB is Railway-managed)

# ---------- listmonk app ----------
LISTMONK_VERSION=latest
LISTMONK_PORT=9000
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=change-me-strong

# Public URL where listmonk is reachable. On Railway, set this to your
# custom domain (e.g. https://letter.jpimiento.dev). Used for opt-in /
# unsubscribe links and webhook signing. Configure inside Settings → General
# after first boot; this value is here so we can reference it from scripts.
LISTMONK_PUBLIC_URL=https://example.com

# ---------- PostgreSQL ----------
# `local` profile spins up a postgres:16 container with these creds.
# `railway` profile ignores db service; instead point LISTMONK_DB_HOST at
# the Railway-managed Postgres add-on (or use the connection string
# Railway injects via DATABASE_URL).
POSTGRES_USER=listmonk
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=listmonk
POSTGRES_PORT=5432

LISTMONK_DB_HOST=db
LISTMONK_DB_PORT=5432
LISTMONK_DB_SSL_MODE=disable     # Railway-managed pg: set to `require`

# ---------- SMTP (listmonk's outbound channel) ----------
# Use any SMTP relay. Preferred zero-cost options:
#   - your own postfix / haraka container
#   - a free tier of an open relay you own
# Listmonk handles its own transactional + bulk delivery via this SMTP.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=change-me
SMTP_AUTH_PROTOCOL=login          # login | cram | plain | none
SMTP_TLS_TYPE=STARTTLS            # STARTTLS | TLS | none
SMTP_HEADERS=[]                   # JSON array of {key,value} pairs, or []

# ---------- Backup ----------
# `backup.sh` writes a gzipped pg_dump here, named YYYYMMDD-HHMMSS.sql.gz.
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14

# ---------- Time zone ----------
TZ=UTC
