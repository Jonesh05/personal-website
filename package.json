{
  "name": "personal-website",
  "version": "1.0.0",
  "private": true,
  "engines": {
      "node": "22.x"
    },
  "workspaces": [
    "frontend",
    "backend",
    "shared",
    "functions"
  ],
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev:frontend": "pnpm run dev --workspace=frontend",
    "dev:backend": "pnpm run dev --workspace=functions",
    "dev": "concurrently \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "build": "pnpm --filter frontend build",
    "deploy": "pnpm run build && firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "install:all": "pnpm install && pnpm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "typescript": "^5.8.3"
  }
}